{
	"name": "tediousjs/node-mssql (v13)",

	"dockerComposeFile": "docker-compose.yml",
	"service": "app",

	"workspaceFolder": "/workspace",

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-mssql.mssql",
				"dbaeumer.vscode-eslint"
			]
		}
	},

	"postCreateCommand": "npm install",

	"containerEnv": {
		"EDITOR": "code --wait",
		"MSSQL_TEST_HOST": "mssql",
		"MSSQL_TEST_PORT": "1433",
		"MSSQL_TEST_USER": "sa",
		"MSSQL_TEST_PASSWORD": "yourStrong(!)Password",
		"MSSQL_TEST_DATABASE": "master"
	}
}
