{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "separate-pull-requests": true,
  "prerelease": true,
  "prerelease-type": "next-major",
  "pull-request-title-pattern": "chore${scope}: release ${version}",
  "pull-request-header": "Release PR generated by release-please. Merging this PR cuts the tag, generates the changelog entry, and (when the npm-publish gate is lifted) publishes to npm under the `next-major` dist-tag. See docs/adr/0005-release-and-ci.md.",
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true },
    { "type": "chore", "section": "Miscellaneous Chores", "hidden": true },
    { "type": "refactor", "section": "Code Refactoring", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Build System", "hidden": true },
    { "type": "ci", "section": "Continuous Integration", "hidden": true }
  ],
  "packages": {
    "packages/core": {
      "package-name": "@tediousjs/mssql-core",
      "component": "mssql-core",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
